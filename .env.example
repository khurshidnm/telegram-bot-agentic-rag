TELEGRAM_BOT_TOKEN=telegram_bot_token
OPENAI_API_KEY=openai_api_key
MONGO_URI=mongodb://localhost:27017/
DB_NAME=telegram_bot
COLLECTION_NAME=chat_history
IMAGE_DRAFT_COLLECTION_NAME=image_learning_drafts

# Comma-separated list of Telegram User IDs with full permissions
SUPER_ADMIN_USER_IDS=123456789

# Comma-separated list of Telegram User IDs allowed to train in groups
TRAINER_ADMIN_USER_IDS=987654321

# Strictness Level for the AI (STRICT, BALANCED, or FLEXIBLE)
STRICTNESS_LEVEL=BALANCED
